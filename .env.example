# HomepageMD — Environment Configuration
#
# Copy this file to .env and adjust values as needed.
# See README.md for full documentation.

# Server port
PORT=2525

# Default page — the .md filename (without extension) served at /
DEFAULT_PAGE=homepage

# Shared passphrase for write endpoints (leave blank to disable auth)
# AUTH_TOKEN=

# Days before a cached favicon is considered stale
# FAVICON_TTL_DAYS=7

# Paths (usually only changed in advanced setups)
# BOOKMARKS_DIR=./bookmarks
# ICONS_DIR=./icons
# FAVICON_CACHE_DIR=./favicon-cache
# CUSTOM_CSS_PATH=./custom.css
